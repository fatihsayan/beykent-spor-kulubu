@{
    ViewData["Title"] = "Ana Sayfa";
}

<!-- HERO BÖLÜMÜ -->
<div class="bg-gradient-primary text-white rounded-4 p-5 mb-5 shadow-lg">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h1 class="display-3 fw-bold mb-3 animate__animated animate__fadeInDown">
                    <i class="bi bi-trophy-fill me-2" style="color: gold;"></i>
                    Beykent Spor Kulübü
                </h1>
                <p class="lead fs-3 mb-4">Profesyonel Sporcu Yönetim Sistemi</p>
                <p class="fs-5 mb-4 opacity-75">Sporcularınızı, aidatlarınızı ve takımlarınızı tek bir platformda yönetin.</p>
                <div class="d-flex gap-3">
                    <a asp-controller="Uyeler" asp-action="Ekle" class="btn btn-warning btn-lg px-4 shadow">
                        <i class="bi bi-person-plus-fill me-2"></i>Yeni Sporcu
                    </a>
                    <a asp-controller="Uyeler" asp-action="Index" class="btn btn-outline-light btn-lg px-4 shadow">
                        <i class="bi bi-people-fill me-2"></i>Tüm Sporcular
                    </a>
                </div>
            </div>
            <div class="col-lg-4 text-center d-none d-lg-block">
                <div class="p-3 bg-white bg-opacity-10 rounded-circle">
                    <i class="bi bi-trophy display-1 text-warning" style="font-size: 8rem;"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- İSTATİSTİK KARTLARI -->
<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center p-4">
                <div class="bg-primary bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                    <i class="bi bi-people-fill text-primary fs-1"></i>
                </div>
                <h3 class="fw-bold mb-1">@ViewBag.ToplamUye</h3>
                <p class="text-muted mb-0">Toplam Sporcu</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center p-4">
                <div class="bg-success bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                    <i class="bi bi-building text-success fs-1"></i>
                </div>
                <h3 class="fw-bold mb-1">@ViewBag.ToplamSalon</h3>
                <p class="text-muted mb-0">Spor Salonu</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body text-center p-4">
                <div class="bg-info bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                    <i class="bi bi-grid-3x3-gap-fill text-info fs-1"></i>
                </div>
                <h3 class="fw-bold mb-1">@ViewBag.ToplamTakim</h3>
                <p class="text-muted mb-0">Takım</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100 border-danger">
            <div class="card-body text-center p-4">
                <div class="bg-danger bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                    <i class="bi bi-exclamation-triangle-fill text-danger fs-1"></i>
                </div>
                <h3 class="fw-bold mb-1">@ViewBag.BorcluUye</h3>
                <p class="text-muted mb-0">Borçlu Sporcu</p>
            </div>
        </div>
    </div>
</div>

<!-- SPOR SALONLARI -->
<h2 class="fw-bold mb-4 position-relative pb-2">
    <i class="bi bi-building me-2 text-primary"></i>
    Spor Salonlarımız
    <span class="position-absolute bottom-0 start-0 w-25 bg-primary" style="height: 3px;"></span>
</h2>

<div class="row g-4 mb-5">
    @if (ViewBag.SporSalonlari != null && ViewBag.SporSalonlari.Count > 0)
    {
        @foreach (var salon in ViewBag.SporSalonlari)
        {
            <div class="col-md-4">
                <a href="/Uyeler?salonId=@salon.Id" class="text-decoration-none">
                    <div class="card border-0 shadow-sm hover-card h-100">
                        <div class="card-body text-center p-4">
                            <div class="bg-primary bg-opacity-10 rounded-circle p-3 d-inline-block mb-3">
                                <i class="bi bi-building fs-1 text-primary"></i>
                            </div>
                            <h4 class="fw-bold text-dark mb-3">@salon.Ad</h4>
                            <span class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-people-fill me-1"></i>Sporcuları Gör
                            </span>
                        </div>
                    </div>
                </a>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-info text-center py-4">
                <i class="bi bi-info-circle-fill me-2 fs-4"></i>
                <span class="fs-5">Henüz spor salonu eklenmemiş.</span>
                <br />
                <a href="/Uyeler/OrnekVeriEkle" class="btn btn-primary mt-3">
                    <i class="bi bi-database-fill me-2"></i>Örnek Verileri Yükle
                </a>
            </div>
        </div>
    }
</div>

<!-- SON EKLENENLER VE HIZLI İŞLEMLER -->
<div class="row g-4">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-4">
                <h5 class="fw-bold mb-0">
                    <i class="bi bi-clock-history text-primary me-2"></i>
                    Son Eklenen Sporcular
                </h5>
            </div>
            <div class="card-body">
                @if (ViewBag.SonUyeler != null && ViewBag.SonUyeler.Count > 0)
                {
                    <div class="list-group list-group-flush">
                        @foreach (var uye in ViewBag.SonUyeler)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <div>
                                    <i class="bi bi-person-circle me-2 text-primary"></i>
                                    <strong>@uye.AdSoyad</strong>
                                    <span class="text-muted ms-2">(@uye.SporSalonu?.Ad ?? "-")</span>
                                </div>
                                <span class="badge bg-info rounded-pill">@uye.KayitTarihi.ToShortDateString()</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted text-center py-3 mb-0">Henüz üye kaydı yok.</p>
                }
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card border-0 shadow-sm bg-primary text-white h-100">
            <div class="card-body text-center p-4">
                <i class="bi bi-lightning-charge-fill display-1 mb-3"></i>
                <h4 class="fw-bold mb-3">Hızlı İşlemler</h4>
                <div class="d-grid gap-2">
                    <a href="/Uyeler/Ekle" class="btn btn-light">
                        <i class="bi bi-person-plus-fill me-2"></i>Yeni Sporcu Ekle
                    </a>
                    <a href="/Uyeler/BorcluUyeler" class="btn btn-warning">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>Borçlu Üyeler
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-gradient-primary {
        background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
    }
    .hover-card {
        transition: transform 0.3s, box-shadow 0.3s;
        cursor: pointer;
    }
    .hover-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
    }
    .list-group-item {
        border-left: none;
        border-right: none;
        transition: background-color 0.3s;
    }
    .list-group-item:hover {
        background-color: #f8f9fa;
    }
</style>