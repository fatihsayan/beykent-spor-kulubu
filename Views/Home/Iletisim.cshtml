@{
    ViewData["Title"] = "İletişim";
}

<div class="container mt-4">
    <h1 class="mb-4">@ViewBag.Message</h1>
    
    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h4>İletişim Bilgileri</h4>
                    <hr />
                    <p><i class="bi bi-geo-alt-fill text-primary me-2"></i> Beylikdüzü / İstanbul</p>
                    <p><i class="bi bi-telephone-fill text-primary me-2"></i> 0 (212) 123 45 67</p>
                    <p><i class="bi bi-envelope-fill text-primary me-2"></i> info@beykentspor.com</p>
                </div>
            </div>
        </div>
        
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h4>Çalışma Saatleri</h4>
                    <hr />
                    <p><strong>Pazartesi - Cuma:</strong> 09:00 - 21:00</p>
                    <p><strong>Cumartesi:</strong> 10:00 - 18:00</p>
                    <p><strong>Pazar:</strong> 10:00 - 14:00</p>
                </div>
            </div>
        </div>
    </div>
</div>