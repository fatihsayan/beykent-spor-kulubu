@model IEnumerable<SporKulubu.Models.Uye>

@{
    ViewData["Title"] = "Ödeme Hatırlatmaları";
}

<div class="container mt-4">
    <h2 class="text-warning mb-4">
        <i class="bi bi-bell-fill me-2"></i>
        Ödeme Hatırlatmaları
    </h2>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card border-warning shadow-sm">
                    <div class="card-header bg-warning text-white">
                        <i class="bi bi-exclamation-circle me-1"></i>
                        Ödeme Gecikmesi
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">@item.AdSoyad</h5>
                        <p class="card-text">
                            <i class="bi bi-telephone me-1"></i> @item.Telefon<br />
                            <i class="bi bi-people me-1"></i> @(item.VeliAdSoyad) - @item.VeliTelefon<br />
                            <i class="bi bi-building me-1"></i> @(item.SporSalonu?.Ad ?? "-")<br />
                            <strong class="text-danger">Borç: @item.ToplamBorc.ToString("C")</strong>
                        </p>
                        <a asp-controller="Aidat" asp-action="Ekle" asp-route-uyeId="@item.Id" class="btn btn-warning btn-sm">
                            <i class="bi bi-cash-plus me-1"></i>Ödeme Kaydet
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>