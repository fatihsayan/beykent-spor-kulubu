@model SporKulubu.Models.Uye

@{
    ViewData["Title"] = "Üye Sil";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-danger">
            <i class="bi bi-trash-fill me-2"></i>
            Üye Sil
        </h2>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Listeye Dön
        </a>
    </div>

    <div class="alert alert-danger">
        <h4 class="alert-heading">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            Dikkat!
        </h4>
        <p>Bu üyeyi silmek istediğinizden emin misiniz? Bu işlem geri alınamaz.</p>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-danger text-white">
            <i class="bi bi-person-badge me-2"></i>Silinecek Üye Bilgileri
        </div>
        <div class="card-body">
            <table class="table table-borderless">
                <tr>
                    <th style="width: 200px">Ad Soyad:</th>
                    <td>@Model.AdSoyad</td>
                </tr>
                <tr>
                    <th>Telefon:</th>
                    <td>@Model.Telefon</td>
                </tr>
                <tr>
                    <th>Doğum Tarihi:</th>
                    <td>@Model.DogumTarihi.ToShortDateString()</td>
                </tr>
                <tr>
                    <th>Veli Ad Soyad:</th>
                    <td>@Model.VeliAdSoyad</td>
                </tr>
                <tr>
                    <th>Veli Telefon:</th>
                    <td>@Model.VeliTelefon</td>
                </tr>
                <tr>
                    <th>Spor Salonu:</th>
                    <td>@(Model.SporSalonu?.Ad ?? "-")</td>
                </tr>
                <tr>
                    <th>Takım:</th>
                    <td>@(Model.Takim?.Ad ?? "-")</td>
                </tr>
                <tr>
                    <th>Grup:</th>
                    <td>@(Model.Grup?.Ad ?? "-")</td>
                </tr>
                <tr>
                    <th>Aylık Aidat:</th>
                    <td>@Model.AylikAidat.ToString("C")</td>
                </tr>
            </table>

            <form asp-action="Sil" method="post" class="mt-4">
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-danger btn-lg px-5">
                    <i class="bi bi-trash me-2"></i>Evet, Sil
                </button>
                <a asp-action="Index" class="btn btn-secondary btn-lg px-5">
                    <i class="bi bi-x-circle me-2"></i>İptal
                </a>
            </form>
        </div>
    </div>
</div>