@model IEnumerable<SporKulubu.Models.Uye>

@{
    ViewData["Title"] = "Borçlu Üyeler";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-danger">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            Borçlu Üyeler
        </h2>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Listeye Dön
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Ad Soyad</th>
                        <th>Telefon</th>
                        <th>Salon</th>
                        <th>Takım</th>
                        <th>Aylık Aidat</th>
                        <th>Son Ödeme</th>
                        <th>Kalan Borç</th>
                        <th>İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.AdSoyad</td>
                            <td>@item.Telefon</td>
                            <td>@(item.SporSalonu?.Ad ?? "-")</td>
                            <td>@(item.Takim?.Ad ?? "-")</td>
                            <td>@item.AylikAidat.ToString("C")</td>
                            <td>@(item.SonAidatOdemeTarihi?.ToShortDateString() ?? "-")</td>
                            <td class="text-danger fw-bold">@item.ToplamBorc.ToString("C")</td>
                            <td>
                                <a asp-action="Detay" asp-route-id="@item.Id" class="btn btn-sm btn-info">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!Model.Any())
            {
                <div class="alert alert-success">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    Borçlu üye bulunmamaktadır. Tebrikler!
                </div>
            }
        </div>
    </div>
</div>